# Supabase Configuration
# ใส่ค่าจาก Supabase Dashboard > Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only Netlify Functions
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_PROJECT_REF=your-supabase-project-ref
SUPABASE_ACCESS_TOKEN=your-supabase-management-access-token
DOAE_USERNAME=your-doae-username
DOAE_PASSWORD=your-doae-password
PPSF_LOGIN_URL=https://report-ppsf.doae.go.th/site/login
PPSF_USERNAME=your-ppsf-username
PPSF_PASSWORD=your-ppsf-password
VISITOR_IP_HASH_SALT=replace-with-random-secret-used-only-on-netlify
GISTDA_API_KEY=your-gistda-api-key-here
METEOSTAT_API_KEY=your-rapidapi-meteostat-key-here

# AI proxy server-only keys
GEMINI_API_KEY=your-gemini-api-key-here
OPENROUTER_API_KEY=your-openrouter-api-key-here
NVIDIA_API_KEY=your-nvidia-api-key-here

# Comma-separated allowed origins for Netlify Functions.
# Example: http://localhost:5173,https://your-site.netlify.app
ALLOWED_ORIGINS=http://localhost:5173

# KKU AI Landing Chatbot Configuration
VITE_LANDING_CHATBOT_API_URL=/api/kku/okmd/api/v1
VITE_LANDING_CHATBOT_API_KEY=your-kku-chatbot-api-key-here
VITE_LANDING_CHATBOT_MODEL=deepseek-v4-flash

# External GIS layer storage, e.g. Cloudflare R2 public/custom-domain URLs.
# Use the metadata URL when a Worker/D1 endpoint returns { geojsonUrl, name }.
VITE_SOIL_LAYER_URL=/gis/soil/nakhon-pathom-soil-series.geojson
VITE_SOIL_LAYER_METADATA_URL=

# LINE Bot Configuration
LINE_CHANNEL_SECRET=your-line-channel-secret-here
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token-here


